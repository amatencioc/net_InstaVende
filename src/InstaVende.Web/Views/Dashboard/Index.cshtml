@{ ViewData["Title"] = "Dashboard"; }

<div class="mb-4">
    <h1 class="topbar-page-title mb-0">Dashboard</h1>
    <p class="text-muted small mb-0 mt-1">@ViewBag.BusinessName</p>
</div>

<!-- KPIs de conversaciones -->
<div class="stat-grid mb-4">
    <div class="stat-tile">
        <div class="st-icon st-b"><i class="bi bi-chat-dots-fill"></i></div>
        <div class="st-val" id="statTotal">—</div>
        <div class="st-lbl">Total conversaciones</div>
    </div>
    <div class="stat-tile">
        <div class="st-icon st-g"><i class="bi bi-check-circle-fill"></i></div>
        <div class="st-val" id="statResolved">—</div>
        <div class="st-lbl">Resueltas</div>
    </div>
    <div class="stat-tile">
        <div class="st-icon st-a"><i class="bi bi-cpu-fill"></i></div>
        <div class="st-val" id="statActive">—</div>
        <div class="st-lbl">Bot activo</div>
    </div>
    <div class="stat-tile">
        <div class="st-icon st-p"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="st-val" id="statRate">—%</div>
        <div class="st-lbl">Tasa de resolución</div>
    </div>
</div>

<!-- KPIs de pedidos -->
<div class="stat-grid mb-4">
    <div class="stat-tile">
        <div class="st-icon st-g"><i class="bi bi-bag-check-fill"></i></div>
        <div class="st-val" id="oKpiMonth">—</div>
        <div class="st-lbl">Pedidos este mes</div>
    </div>
    <div class="stat-tile">
        <div class="st-icon st-b"><i class="bi bi-currency-dollar"></i></div>
        <div class="st-val" id="oKpiRevenue">—</div>
        <div class="st-lbl">Ingresos este mes</div>
    </div>
    <div class="stat-tile">
        <div class="st-icon st-a"><i class="bi bi-hourglass-split"></i></div>
        <div class="st-val" id="oKpiPending">—</div>
        <div class="st-lbl">Pedidos pendientes</div>
    </div>
    <div class="stat-tile">
        <div class="st-icon st-g"><i class="bi bi-box-seam-fill"></i></div>
        <div class="st-val" id="oKpiDelivered">—</div>
        <div class="st-lbl">Entregados</div>
    </div>
</div>

<!-- Gráficos -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="a-card h-100">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-graph-up"></i> Conversaciones — últimos 30 días</div></div>
            <div class="a-card-body"><canvas id="chartDaily" height="100"></canvas></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="a-card h-100">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-pie-chart"></i> Por canal</div></div>
            <div class="a-card-body"><canvas id="chartChannel" height="200"></canvas></div>
        </div>
    </div>
</div>

<!-- Accesos rápidos -->
<div class="row g-3">
    <div class="col-12">
        <div class="a-card">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-lightning-charge-fill"></i> Accesos rápidos</div></div>
            <div class="a-card-body d-flex flex-wrap gap-3">
                <a asp-controller="Inbox" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-chat-dots me-1"></i>Ver bandeja</a>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-bag-check me-1"></i>Ver pedidos</a>
                <a asp-controller="Products" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-plus-circle me-1"></i>Agregar producto</a>
                <a asp-controller="Reminders" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-alarm me-1"></i>Recordatorios</a>
                <a asp-controller="PaymentMethods" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-credit-card me-1"></i>Métodos de pago</a>
                <a asp-controller="Bot" asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-cpu me-1"></i>Configurar bot</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function() {
    $.getJSON('/Dashboard/GetStats', function(d) {
        $('#statTotal').text(d.totalConversations);
        $('#statResolved').text(d.resolvedConversations);
        $('#statActive').text(d.activeConversations);
        $('#statRate').text(d.resolutionRate + '%');
        new Chart(document.getElementById('chartDaily'), {
            type: 'line',
            data: { labels: d.dailyConversations.map(x => x.date), datasets: [{ label: 'Conversaciones', data: d.dailyConversations.map(x => x.count), borderColor: '#16a34a', tension: 0.3, fill: true, backgroundColor: 'rgba(22,163,74,0.08)' }] },
            options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
        });
        new Chart(document.getElementById('chartChannel'), {
            type: 'doughnut',
            data: { labels: d.conversationsByChannel.map(x => x.channel), datasets: [{ data: d.conversationsByChannel.map(x => x.count), backgroundColor: ['#25D366','#1877F2','#E1306C'] }] },
            options: { plugins: { legend: { position: 'bottom' } } }
        });
    });
    $.getJSON('/Orders/GetStats', function(d) {
        $('#oKpiMonth').text(d.totalMonth);
        $('#oKpiRevenue').text('$' + (d.revenueMonth || 0).toLocaleString('es', {minimumFractionDigits:2}));
        $('#oKpiPending').text(d.pending);
        $('#oKpiDelivered').text(d.delivered);
    });
});
</script>
}

