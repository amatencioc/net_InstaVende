        </div>
    </div>

    <!-- Side info -->
    <div class="col-lg-4">
        <div class="a-card">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-shield-check"></i> żPor qué usar API?</div></div>
            <div class="a-card-body">
                <ul class="list-unstyled mb-0" style="font-size:.84rem;line-height:2">
                    <li><i class="bi bi-check2-circle text-success me-2"></i>Respuestas automáticas 24/7</li>
                    <li><i class="bi bi-check2-circle text-success me-2"></i>Manejo de miles de conversaciones</li>
                    <li><i class="bi bi-check2-circle text-success me-2"></i>Catálogo integrado de productos</li>
                    <li><i class="bi bi-check2-circle text-success me-2"></i>Recordatorios automáticos</li>
                    <li><i class="bi bi-check2-circle text-success me-2"></i>Métricas de ventas en tiempo real</li>
                    <li><i class="bi bi-check2-circle text-success me-2"></i>Seguro y verificado por Meta</li>
                </ul>
            </div>
        </div>
        <div class="a-card">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-life-preserver"></i> żNecesitas ayuda?</div></div>
            <div class="a-card-body">
                <p class="text-muted mb-3" style="font-size:.85rem">Nuestro equipo puede guiarte paso a paso en la conexión.</p>
                <a href="mailto:soporte@instavende.com" class="btn btn-outline-primary w-100 mb-2">
                    <i class="bi bi-envelope me-2"></i>Escribir al soporte
                </a>
                <a href="https://developers.facebook.com/docs/whatsapp/cloud-api/get-started" target="_blank" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-box-arrow-up-right me-2"></i>Documentación Meta
                </a>
            </div>
        </div>
    </div>
</div>
</div><!-- /stateMain -->

@section Scripts {
@Html.AntiForgeryToken()

<script>
  /* ?? Meta config values ???????????????????????????????????? */
  var META_APP_ID  = '@metaAppId';
  var META_CFG_ID  = '@configId';
  var META_READY   = false;

  /* ?? Facebook SDK ?????????????????????????????????????????? */
  window.fbAsyncInit = function() {
    if (!META_APP_ID) return;
    FB.init({ appId: META_APP_ID, cookie: true, xfbml: false, version: 'v20.0' });
    META_READY = true;
  };
  (function(d, s, id) {
    if (!META_APP_ID || d.getElementById(id)) return;
    var js = d.createElement(s); js.id = id;
    js.src = 'https://connect.facebook.net/es_LA/sdk.js';
    js.onerror = function() { console.error('Error cargando el SDK de Facebook.'); };
    d.getElementsByTagName(s)[0].parentNode.insertBefore(js, d.getElementsByTagName(s)[0]);
  }(document, 'script', 'facebook-jssdk'));

  /* ?? State switcher ???????????????????????????????????????? */
  function showState(name) {
    ['main','connecting','success','error'].forEach(function(s) {
      var el = document.getElementById('state' + s.charAt(0).toUpperCase() + s.slice(1));
      if (el) el.style.display = (s === name) ? '' : 'none';
    });
  }

  /* ?? Reset connect button ?????????????????????????????????? */
  function resetBtn() {
    var btn = document.getElementById('btnConnect');
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-whatsapp me-2"></i>Conectar WhatsApp'; }
  }

  /* ?? Show error state ?????????????????????????????????????? */
  function showError(msg) {
    resetBtn();
    showState('error');
    var el = document.getElementById('errorMsg');
    if (el) el.textContent = msg || 'Ocurrió un error durante la vinculación.';
  }

  /* ?? Launch Embedded Signup ???????????????????????????????? */
  function launchEmbeddedSignup() {
    /* 1. Check Meta is configured */
    if (!META_APP_ID) {
      alert('La app de Meta no está configurada en el servidor.\nContacta al administrador o agrega Meta:AppId en appsettings.json.');
      return;
    }

    /* 2. Check SDK loaded */
    if (typeof FB === 'undefined' || !META_READY) {
      alert('El SDK de Facebook todavía no está listo. Espera unos segundos y vuelve a intentarlo.');
      return;
    }

    /* 3. Disable button */
    var btn = document.getElementById('btnConnect');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Cargando...'; }

    /* 4. Open Facebook Login */
    try {
      FB.login(function(response) {
        if (!response || !response.authResponse) {
          showError('Se canceló el proceso o no se otorgaron los permisos necesarios.');
          return;
        }

        var code = response.authResponse.code;
        if (!code) { showError('Meta no devolvió un código de autorización válido.'); return; }

        /* 5. Extract WABA + phone_number_id from session_info */
        var wabaId = null, phoneNumberId = null;
        try {
          var extras = response.authResponse.extra_data_list;
          if (extras && extras.length) {
            var info = extras[0];
            wabaId        = info.waba_id        || info.wabaId        || null;
            phoneNumberId = info.phone_number_id || info.phoneNumberId || null;
          }
        } catch(e) { console.warn('No se pudo leer session_info:', e); }

        saveEmbeddedSignup(code, wabaId, phoneNumberId);

      }, {
        config_id: META_CFG_ID,
        response_type: 'code',
        override_default_response_type: true,
        extras: { setup: {}, featureType: '', sessionInfoVersion: '3' }
      });
    } catch(e) {
      showError('Error al abrir el diálogo de Facebook: ' + e.message);
    }
  }

  /* ?? Send code to backend ?????????????????????????????????? */
  function saveEmbeddedSignup(code, wabaId, phoneNumberId) {
    showState('connecting');
    setConnectingMsg('Verificando con Meta...');

    var token = '';
    var tokenInput = document.querySelector('[name="__RequestVerificationToken"]');
    if (tokenInput) token = tokenInput.value;

    setTimeout(function() { setConnectingMsg('Guardando configuración...'); }, 2000);

    fetch('/ChannelConfig/EmbeddedSignup', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': token
      },
      body: JSON.stringify({ code: code, wabaId: wabaId, phoneNumberId: phoneNumberId })
    })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(e) { throw new Error(e.error || 'Error HTTP ' + r.status); });
      return r.json();
    })
    .then(function(data) {
      if (data.success) {
        setConnectingMsg('ˇConexión establecida!');
        setTimeout(function() { showState('success'); }, 600);
      } else {
        showError(data.error || 'Error al guardar la configuración.');
      }
    })
    .catch(function(err) {
      showError(err.message || 'Error de conexión con el servidor. Intenta de nuevo.');
    });
  }

  function setConnectingMsg(text) {
    var el = document.getElementById('connectingMsg');
    if (el) el.textContent = text;
  }
</script>

<style>
@@keyframes wa-pulse {
  0%, 100% { transform: scale(1);   opacity: 1;   }
  50%       { transform: scale(1.1); opacity: .75; }
}
</style>
}

