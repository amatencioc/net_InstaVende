@{
    ViewData["Title"] = "WhatsApp";
    bool isConnected  = ViewBag.IsConnected == true;
    string phoneNumber = ViewBag.PhoneNumber as string ?? "";
    DateTime? connectedAt = ViewBag.ConnectedAt as DateTime?;
}

<div class="page-header mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a href="/ChannelConfig" class="text-muted">Canales</a></li>
            <li class="breadcrumb-item active">WhatsApp</li>
        </ol>
    </nav>
    <h1 class="topbar-page-title mb-0"><i class="bi bi-whatsapp me-2" style="color:#25D366"></i>WhatsApp</h1>
    <p class="text-muted small mb-0 mt-1">Conecta tu numero escaneando el codigo QR desde tu celular</p>
    <div class="mt-2">
        <span id="svcBadge" class="badge rounded-pill px-3 py-2" style="font-size:.78rem;display:none"></span>
    </div>
</div>

<div class="wa-layout">

@if (isConnected)
{
    <!-- === CONECTADO === -->
    <div class="wa-qr-col">
        <div class="a-card">
            <div class="a-card-body text-center" style="padding:2.5rem 2rem">
                <div class="wa-status-icon wa-status-icon--ok mx-auto mb-3">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <h4 class="fw-bold mb-1">WhatsApp conectado</h4>
                <p class="text-muted mb-3" style="font-size:.88rem">El bot esta activo y respondiendo mensajes.</p>
                @if (!string.IsNullOrEmpty(phoneNumber))
                {
                    <div class="wa-phone-badge mx-auto mb-3">
                        <i class="bi bi-whatsapp"></i>+@phoneNumber
                    </div>
                }
                @if (connectedAt.HasValue)
                {
                    <p class="text-muted mb-4" style="font-size:.8rem">
                        Conectado el @connectedAt.Value.ToLocalTime().ToString("d MMM yyyy", new System.Globalization.CultureInfo("es-PE"))
                    </p>
                }
                else { <div class="mb-4"></div> }
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a href="/Inbox" class="btn btn-primary">
                        <i class="bi bi-chat-dots me-1"></i>Ir a Mensajes
                    </a>
                    <form asp-action="Disconnect" method="post" id="frmDisconnect" onsubmit="return false">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn btn-outline-danger" onclick="confirmDisconnect()">
                            <i class="bi bi-plug me-1"></i>Desconectar
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="wa-info-col">
        <div class="a-card">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-info-circle"></i>Estado del servicio</div></div>
            <div class="a-card-body">
                <div class="wa-info-item">
                    <i class="bi bi-shield-check text-success"></i>
                    <div>
                        <div class="fw-semibold" style="font-size:.85rem">Sesion activa</div>
                        <div class="text-muted" style="font-size:.78rem">La sesion se mantiene activa automaticamente</div>
                    </div>
                </div>
                <div class="wa-info-item">
                    <i class="bi bi-robot" style="color:#7c3aed"></i>
                    <div>
                        <div class="fw-semibold" style="font-size:.85rem">Bot respondiendo</div>
                        <div class="text-muted" style="font-size:.78rem">Los mensajes entrantes se procesan con IA</div>
                    </div>
                </div>
                <div class="wa-info-item">
                    <i class="bi bi-arrow-repeat" style="color:#f59e0b"></i>
                    <div>
                        <div class="fw-semibold" style="font-size:.85rem">Reconexion automatica</div>
                        <div class="text-muted" style="font-size:.78rem">El servicio se reinicia solo si se desconecta</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- === DESCONECTADO / QR === -->
    <div class="wa-qr-col">
        <div class="a-card">
            <div class="a-card-body" style="padding:2rem">

                <div class="text-center mb-4">
                    <div class="wa-status-icon wa-status-icon--idle mx-auto mb-3">
                        <i class="bi bi-whatsapp"></i>
                    </div>
                    <h4 class="fw-bold mb-1">Escanea el codigo QR</h4>
                    <p class="text-muted mb-0" style="font-size:.86rem">
                        Abre WhatsApp &rarr; <strong>Dispositivos vinculados</strong> &rarr; <strong>Vincular dispositivo</strong>
                    </p>
                </div>

                <!-- Vista: cargando / inicializando -->
                <div id="viewSpinner" class="qr-view text-center py-4">
                    <div class="spinner-border text-success mb-3" style="width:2.5rem;height:2.5rem"></div>
                    <p id="spinnerText" class="text-muted mb-0" style="font-size:.84rem">Iniciando servicio...</p>
                </div>

                <!-- Vista: QR listo -->
                <div id="viewQr" class="qr-view text-center" style="display:none">
                    <div class="d-inline-flex flex-column align-items-center gap-2">
                        <img id="qrImage" src="" alt="QR WhatsApp" class="qr-img" />
                        <div class="qr-progress-wrap">
                            <div id="qrBar" class="qr-progress-bar"></div>
                        </div>
                        <span id="qrTimer" class="text-muted" style="font-size:.78rem"></span>
                    </div>
                </div>

                <!-- Vista: autenticando (QR escaneado) -->
                <div id="viewAuth" class="qr-view text-center py-4" style="display:none">
                    <div class="spinner-border text-success mb-3" style="width:2.5rem;height:2.5rem"></div>
                    <p class="text-muted mb-0" style="font-size:.84rem">
                        <i class="bi bi-shield-check me-1"></i>QR escaneado, verificando sesion...
                    </p>
                </div>

                <!-- Vista: error / servicio offline -->
                <div id="viewError" class="qr-view text-center py-3" style="display:none">
                    <i class="bi bi-exclamation-triangle-fill text-warning d-block mb-2" style="font-size:2rem"></i>
                    <p class="fw-semibold mb-1" style="font-size:.9rem;color:#1e293b">No se pudo mostrar el codigo QR.</p>
                    <p id="errorDetail" class="text-muted mb-4" style="font-size:.82rem">El servicio no esta disponible.</p>
                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <button class="btn btn-success px-4" id="btnGetQr" onclick="WaQr.getQr()">
                            <i class="bi bi-qr-code me-2"></i>Obtener codigo QR
                        </button>
                        <button class="btn btn-outline-secondary px-4" id="btnClearSession" onclick="WaQr.clearSession()" title="Elimina la sesion guardada para forzar un QR fresco">
                            <i class="bi bi-trash me-1"></i>Limpiar sesion
                        </button>
                    </div>
                    <p class="text-muted mt-2 mb-0" style="font-size:.75rem">
                        żEl QR nunca aparece? Usa <strong>Limpiar sesion</strong> para borrar una sesion corrupta.
                    </p>
                    <p id="restartMsg" class="mt-2 mb-0 small"></p>
                </div>

                <!-- Barra de estado (visible cuando QR o auth) -->
                <div id="statusBar" class="wa-status-bar mt-3" style="display:none">
                    <span id="statusSpinner" class="spinner-border spinner-border-sm text-secondary flex-shrink-0"></span>
                    <span id="statusText" class="small text-muted">Procesando...</span>
                </div>

            </div>
        </div>
    </div>

    <!-- Instrucciones + info -->
    <div class="wa-info-col">
        <div class="a-card mb-3">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-list-ol"></i>Como conectar</div></div>
            <div class="a-card-body">
                <ol class="wa-steps">
                    <li>Abre <strong>WhatsApp</strong> en tu celular</li>
                    <li>Toca <strong>Mas opciones</strong> &rarr; <strong>Dispositivos vinculados</strong></li>
                    <li>Toca <strong>Vincular un dispositivo</strong></li>
                    <li>Apunta la camara al codigo QR de la izquierda</li>
                </ol>
            </div>
        </div>
        <div class="a-card">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-lightbulb"></i>Ten en cuenta</div></div>
            <div class="a-card-body">
                <div class="wa-info-item">
                    <i class="bi bi-clock" style="color:#f59e0b"></i>
                    <div>
                        <div class="fw-semibold" style="font-size:.85rem">El QR expira en 20 segundos</div>
                        <div class="text-muted" style="font-size:.78rem">Se genera uno nuevo automaticamente</div>
                    </div>
                </div>
                <div class="wa-info-item">
                    <i class="bi bi-wifi" style="color:#2563eb"></i>
                    <div>
                        <div class="fw-semibold" style="font-size:.85rem">Tu celular necesita internet</div>
                        <div class="text-muted" style="font-size:.78rem">WhatsApp Web requiere conexion activa</div>
                    </div>
                </div>
                <div class="wa-info-item">
                    <i class="bi bi-shield-check text-success"></i>
                    <div>
                        <div class="fw-semibold" style="font-size:.85rem">Sesion segura y persistente</div>
                        <div class="text-muted" style="font-size:.78rem">No necesitas volver a escanear cada vez</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

</div><!-- /.wa-layout -->

@Html.AntiForgeryToken()

<script>
(function () {
  'use strict';

  var STATUS_URL          = '/ChannelConfig/WaStatus';
  var SAVE_URL            = '/ChannelConfig/SaveQrConnection';
  var RESTART_URL         = '/ChannelConfig/WaRestart';
  var RESTART_STATUS_URL  = '/ChannelConfig/WaRestartStatus';
  var CLEAR_SESSION_URL   = '/ChannelConfig/ClearWaSession';
  var QR_TTL_MS   = 18000;
  var MAX_ERRORS  = 8;
  var POLL_FAST   = 1000;
  var POLL_NORMAL = 2000;
  var POLL_SLOW   = 5000;   // used after 'disconnected' — Node reinits in ~5s

  var _timer           = null;
  var _cTimer          = null;
  var _rsTimer         = null;  // restart-status poll timer
  var _errors          = 0;
  var _lastQrUrl       = null;
  var _lastQrHash      = null;   // ETag surrogate: skip re-rendering if QR unchanged
  var _saving          = false;
  var _restarting      = false;
  var _restartAttempts = 0;      // número de reintentos auto-restart visibles en la UI

  var el = {
    viewSpinner:   document.getElementById('viewSpinner'),
    viewQr:        document.getElementById('viewQr'),
    viewAuth:      document.getElementById('viewAuth'),
    viewError:     document.getElementById('viewError'),
    spinnerText:   document.getElementById('spinnerText'),
    qrImage:       document.getElementById('qrImage'),
    qrBar:         document.getElementById('qrBar'),
    qrTimer:       document.getElementById('qrTimer'),
    statusBar:     document.getElementById('statusBar'),
    statusSpinner: document.getElementById('statusSpinner'),
    statusText:    document.getElementById('statusText'),
    errorDetail:   document.getElementById('errorDetail'),
    btnGetQr:      document.getElementById('btnGetQr'),
    btnClearSession: document.getElementById('btnClearSession'),
    restartMsg:    document.getElementById('restartMsg'),
  };

  // Guard: only active on the QR / not-connected page
  if (!el.viewSpinner) {
    // En la vista conectada aún queremos el indicador de servicio
    (function svcIndicatorConnected() {
      var badge = document.getElementById('svcBadge');
      if (!badge) return;
      function updateBadge() {
        fetch(STATUS_URL, { cache: 'no-store' })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) {
            if (!d) { badge.style.display = 'none'; return; }
            var online = d.connected === true || (d.state && d.state !== 'disconnected');
            badge.style.display    = '';
            badge.style.background = online ? '#dcfce7' : '#fee2e2';
            badge.style.color      = online ? '#166534' : '#991b1b';
            badge.innerHTML = online
              ? '<i class="bi bi-circle-fill me-1" style="font-size:.55rem;vertical-align:middle"></i>Servicio online'
              : '<i class="bi bi-circle-fill me-1" style="font-size:.55rem;vertical-align:middle"></i>Servicio offline';
          })
          .catch(function () { badge.style.display = 'none'; });
      }
      updateBadge();
      setInterval(updateBadge, 5000);
    }());
    return;
  }

  // Public API
  window.WaQr = { getQr: getQr, start: start, clearSession: clearSession };

  // ?? helpers ???????????????????????????????????????????????????????????????
  function tok() {
    var inp = document.querySelector('input[name="__RequestVerificationToken"]');
    return inp ? inp.value : '';
  }
  function clearTimer()             { if (_timer)   { clearTimeout(_timer);   _timer   = null; } }
  function clearCountdown()         { if (_cTimer)  { clearTimeout(_cTimer);  _cTimer  = null; } }
  function clearRestartStatusTimer(){ if (_rsTimer) { clearTimeout(_rsTimer); _rsTimer = null; } }

  function showView(name) {
    el.viewSpinner.style.display = name === 'spinner' ? '' : 'none';
    el.viewQr.style.display      = name === 'qr'      ? '' : 'none';
    el.viewAuth.style.display    = name === 'auth'    ? '' : 'none';
    el.viewError.style.display   = name === 'error'   ? '' : 'none';
    el.statusBar.style.display   = (name === 'qr' || name === 'auth') ? 'flex' : 'none';
  }

  function setStatus(text, spinning) {
    if (el.statusText)    el.statusText.textContent      = text;
    if (el.statusSpinner) el.statusSpinner.style.display = spinning ? '' : 'none';
  }

  function resetBtn() {
    if (el.btnGetQr) {
      el.btnGetQr.disabled  = false;
      el.btnGetQr.innerHTML = '<i class="bi bi-qr-code me-2"></i>Obtener codigo QR';
    }
    if (el.btnClearSession) {
      el.btnClearSession.disabled  = false;
      el.btnClearSession.innerHTML = '<i class="bi bi-trash me-1"></i>Limpiar sesion';
    }
  }

  // ?? limpiar sesion Node (fuerza QR fresco) ???????????????????????????????????????????
  function clearSession() {
    if (el.btnClearSession) {
      el.btnClearSession.disabled  = true;
      el.btnClearSession.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Limpiando...';
    }
    if (el.restartMsg) el.restartMsg.textContent = '';

    fetch(CLEAR_SESSION_URL, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': tok() },
      body:    '{}',
    })
    .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function (d) {
      if (el.restartMsg) {
        el.restartMsg.textContent = d.message || (d.ok ? 'Sesion eliminada.' : 'No se pudo eliminar.');
        el.restartMsg.className   = 'mt-2 mb-0 small ' + (d.ok ? 'text-success' : 'text-danger');
      }
      if (d.ok) {
        // Esperar 1 s para que el usuario lea el mensaje y luego reiniciar servicio
        setTimeout(function () { getQr(); }, 1200);
      } else {
        resetBtn();
      }
    })
    .catch(function (err) {
      console.error('[WaQr] clearSession:', err.message);
      if (el.restartMsg) {
        el.restartMsg.textContent = 'Error de red al limpiar la sesion.';
        el.restartMsg.className   = 'mt-2 mb-0 small text-danger';
      }
      resetBtn();
    });
  }

  // ?? countdown bar ?????????????????????????????????????????????????????????
  function startCountdown(iso) {
    clearCountdown();
    var end = new Date(iso).getTime();
    (function tick() {
      var rem  = Math.max(0, end - Date.now());
      var pct  = (rem / QR_TTL_MS) * 100;
      var secs = Math.ceil(rem / 1000);
      if (el.qrBar) {
        el.qrBar.style.width      = pct + '%';
        el.qrBar.style.background = pct > 50 ? '#25D366' : pct > 25 ? '#f59e0b' : '#ef4444';
      }
      if (el.qrTimer) el.qrTimer.textContent = secs > 0 ? 'Expira en ' + secs + ' s' : 'Generando nuevo QR...';
      if (rem > 0) _cTimer = setTimeout(tick, 500);
    }());
  }

  function stopCountdown() {
    clearCountdown();
    if (el.qrBar)   { el.qrBar.style.width = '100%'; el.qrBar.style.background = '#25D366'; }
    if (el.qrTimer) el.qrTimer.textContent = '';
  }

  // ?? main poll loop ????????????????????????????????????????????????????????
  function start() {
    _errors          = 0;
    _saving          = false;
    _restarting      = false;
    _lastQrUrl       = null;
    _lastQrHash      = null;
    _restartAttempts = 0;
    clearTimer();
    clearRestartStatusTimer();
    stopCountdown();
    showView('spinner');
    if (el.spinnerText) el.spinnerText.textContent = 'Iniciando servicio...';
    poll();
  }

  function poll() {
    if (document.hidden) { _timer = setTimeout(poll, 5000); return; }

    // Append the current QR hash so the server can skip sending the base64 if unchanged
    var url = STATUS_URL + (_lastQrHash ? '?qrHash=' + _lastQrHash : '');
    fetch(url, { cache: 'no-store' })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function (data) { _errors = 0; dispatch(data); })
      .catch(function (err) {
        _errors++;
        console.warn('[WaQr] poll #' + _errors + ':', err.message);
        if (_errors >= MAX_ERRORS) {
          stopCountdown();
          showView('error');
          if (el.errorDetail) el.errorDetail.textContent = 'El servicio no esta disponible en este momento.';
          resetBtn();
          return;
        }
        setStatus('Reintentando... (' + _errors + '/' + MAX_ERRORS + ')', true);
        _timer = setTimeout(poll, POLL_NORMAL * 2);
      });
  }

  function dispatch(data) {
    var state = data.state || (data.connected ? 'connected' : 'initializing');

    if (state === 'connected') {
      if (_saving) return;
      _saving = true;
      clearTimer();
      stopCountdown();
      showView('spinner');
      if (el.spinnerText) el.spinnerText.textContent = 'Conectado. Guardando sesion...';
      saveConnection(data.info);
      return;
    }

    if (state === 'authenticating') {
      clearTimer();
      stopCountdown();
      showView('auth');
      setStatus('QR escaneado, verificando...', true);
      _timer = setTimeout(poll, POLL_FAST);
      return;
    }

    if (state === 'qr') {
      // Server sends qrDataUrl=null + unchanged=true when the QR hasn't changed
      if (data.qrHash) _lastQrHash = data.qrHash;
      var newQrUrl = data.qrDataUrl;
      if (newQrUrl && newQrUrl !== _lastQrUrl) {
        _lastQrUrl = newQrUrl;
        if (el.qrImage) el.qrImage.src = newQrUrl;
        stopCountdown();
        if (data.qrExpiresAt) startCountdown(data.qrExpiresAt);
      } else if (!newQrUrl && !data.unchanged) {
        // QR not yet encoded — stay on spinner
        if (el.spinnerText) el.spinnerText.textContent = 'Generando codigo QR...';
        showView('spinner');
        _timer = setTimeout(poll, POLL_NORMAL);
        return;
      }
      if (_lastQrUrl) {
        showView('qr');
        setStatus('Escanea el QR con tu celular', true);
      } else {
        if (el.spinnerText) el.spinnerText.textContent = 'Generando codigo QR...';
        showView('spinner');
      }
      _timer = setTimeout(poll, POLL_NORMAL);
      return;
    }

    if (state === 'disconnected') {
      // Consultar WaRestartStatus para distinguir entre "offline" y "reiniciando Puppeteer"
      stopCountdown();
      showView('spinner');
      setStatus('Esperando al servicio...', true);
      clearRestartStatusTimer();
      fetch(RESTART_STATUS_URL, { cache: 'no-store' })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (rs) {
          if (!rs) return;
          if (rs.restarting) {
            var attempt = rs.failCount > 0 ? rs.failCount : (_restartAttempts + 1);
            _restartAttempts = attempt;
            if (el.spinnerText)
              el.spinnerText.textContent = 'Reiniciando servicio... (intento ' + attempt + ')';
          } else {
            if (el.spinnerText)
              el.spinnerText.textContent = 'Reconectando, espera un momento...';
          }
        })
        .catch(function () {
          if (el.spinnerText) el.spinnerText.textContent = 'Reconectando, espera un momento...';
        });
      _timer = setTimeout(poll, POLL_SLOW);
      return;
    }

    // initializing or unknown — poll fast so QR appears as soon as it's ready
    if (el.spinnerText) el.spinnerText.textContent = 'Iniciando, por favor espera...';
    showView('spinner');
    _timer = setTimeout(poll, POLL_FAST);
  }

  // ?? persist session to DB ?????????????????????????????????????????????????
  function saveConnection(info) {
    fetch(SAVE_URL, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': tok() },
      body:    JSON.stringify({ phone: info ? (info.phone || info.wid || null) : null }),
    })
    .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function () { window.location.reload(); })
    .catch(function (err) {
      console.error('[WaQr] saveConnection:', err.message);
      _saving = false;
      showView('error');
      if (el.errorDetail) el.errorDetail.textContent = 'Error al guardar la conexion. Intenta de nuevo.';
      resetBtn();
    });
  }

  // ?? manual "Obtener QR" ????????????????????????????????????????????????????
  function getQr() {
    if (_restarting) return;
    _restarting = true;
    _errors     = 0;

    if (el.btnGetQr) {
      el.btnGetQr.disabled  = true;
      el.btnGetQr.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Iniciando...';
    }
    if (el.restartMsg) el.restartMsg.textContent = '';

    fetch(RESTART_URL, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': tok() },
      body:    '{}',
    })
    .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function (d) {
      _restarting = false;
      if (d.ok) {
        start();  // service started (or was already running) — begin polling
      } else {
        resetBtn();
        if (el.restartMsg) {
          el.restartMsg.textContent = d.message || 'No se pudo iniciar el servicio.';
          el.restartMsg.className   = 'mt-3 mb-0 small text-danger';
        }
      }
    })
    .catch(function (err) {
      console.error('[WaQr] getQr:', err.message);
      _restarting = false;
      resetBtn();
      if (el.restartMsg) {
        el.restartMsg.textContent = 'Error de red. Verifica tu conexion e intenta de nuevo.';
        el.restartMsg.className   = 'mt-3 mb-0 small text-danger';
      }
    });
  }

  // Resume when tab becomes visible again
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden && !_saving && !_restarting) { clearTimer(); poll(); }
  });

  // Boot
  start();

  // ?? indicador online/offline del servicio Node (vista QR) ???????????????????
  (function svcIndicator() {
    var badge = document.getElementById('svcBadge');
    if (!badge) return;
    function updateBadge() {
      fetch(STATUS_URL, { cache: 'no-store' })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) {
          if (!d) { badge.style.display = 'none'; return; }
          var online = d.connected === true || (d.state && d.state !== 'disconnected');
          badge.style.display    = '';
          badge.style.background = online ? '#dcfce7' : '#fee2e2';
          badge.style.color      = online ? '#166534' : '#991b1b';
          badge.innerHTML = online
            ? '<i class="bi bi-circle-fill me-1" style="font-size:.55rem;vertical-align:middle"></i>Servicio online'
            : '<i class="bi bi-circle-fill me-1" style="font-size:.55rem;vertical-align:middle"></i>Servicio offline';
        })
        .catch(function () { badge.style.display = 'none'; });
    }
    updateBadge();
    setInterval(updateBadge, 5000);
  }());

}());

function confirmDisconnect() {
    ivConfirm({
        title:   '\u00bfDesconectar WhatsApp?',
        message: 'El bot dejar\u00e1 de responder mensajes hasta que vuelvas a conectar.',
        okLabel: 'Desconectar',
        type:    'danger'
    }).then(function (ok) {
        if (ok) document.getElementById('frmDisconnect').submit();
    });
}
</script>
