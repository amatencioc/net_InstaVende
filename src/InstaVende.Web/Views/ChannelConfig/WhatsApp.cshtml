@{
    ViewData["Title"] = "Conectar WhatsApp";
    bool isConnected = ViewBag.IsConnected == true;
    string phoneNumberId = ViewBag.PhoneNumberId ?? "";
    string phoneNumber = ViewBag.PhoneNumber ?? "";
    DateTime? connectedAt = ViewBag.ConnectedAt as DateTime?;
    string metaAppId = ViewBag.MetaAppId ?? "";
    string configId = ViewBag.EmbeddedSignupConfigId ?? "";
}

<!-- Breadcrumb -->
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1" style="font-size:.78rem">
            <li class="breadcrumb-item"><a href="/ChannelConfig" class="text-muted">Canales</a></li>
            <li class="breadcrumb-item active">WhatsApp</li>
        </ol>
    </nav>
    <h1 class="topbar-page-title mb-0">Conectar WhatsApp Business</h1>
</div>

@if (string.IsNullOrEmpty(metaAppId))
{
    <div class="app-alert app-alert-error mb-4">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>Meta App no configurada.</strong>
            Para habilitar la conexión, ingresa tu <code>Meta:AppId</code>, <code>Meta:AppSecret</code> y <code>Meta:EmbeddedSignupConfigId</code>
            en <code>appsettings.json</code> (o en las variables de entorno del servidor).
            <a href="https://developers.facebook.com/apps/" target="_blank" class="ms-2 fw-bold">Crear app en Meta ?</a>
        </div>
    </div>
}

<!-- ?? CONNECTING overlay (hidden by default) ?????????????????????????????? -->
<div id="stateConnecting" style="display:none">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="a-card text-center" style="padding:3rem 2rem">
                <div class="mb-4" style="position:relative;display:inline-block">
                    <!-- Pulsing ring -->
                    <div style="width:100px;height:100px;border-radius:50%;background:rgba(22,163,74,.08);display:flex;align-items:center;justify-content:center;margin:0 auto;animation:wa-pulse 1.8s ease-in-out infinite">
                        <div style="width:72px;height:72px;border-radius:50%;background:rgba(22,163,74,.14);display:flex;align-items:center;justify-content:center">
                            <i class="bi bi-whatsapp" style="font-size:2rem;color:#25D366"></i>
                        </div>
                    </div>
                </div>
                <h4 style="font-family:var(--font-heading);font-weight:700;color:#0f172a;margin-bottom:.5rem">Conectando tu cuenta</h4>
                <p class="text-muted mb-4" style="font-size:.88rem">Esto puede tardar unos instantes...</p>
                <div class="d-flex justify-content-center gap-2 mb-2">
                    <span class="spinner-border spinner-border-sm text-success"></span>
                    <span id="connectingMsg" style="font-size:.84rem;color:#475569">Verificando con Meta...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ?? SUCCESS state (hidden by default) ?????????????????????????????????? -->
<div id="stateSuccess" style="display:none">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="a-card text-center" style="padding:3rem 2rem">
                <div style="width:100px;height:100px;border-radius:50%;background:rgba(22,163,74,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
                    <div style="width:72px;height:72px;border-radius:50%;background:#dcfce7;display:flex;align-items:center;justify-content:center">
                        <i class="bi bi-check-circle-fill" style="font-size:2rem;color:#16a34a"></i>
                    </div>
                </div>
                <h4 style="font-family:var(--font-heading);font-weight:700;color:#0f172a;margin-bottom:.5rem">
                    Tu cuenta está conectada a InstaVende
                </h4>
                <p class="text-muted mb-4" style="font-size:.88rem">
                    Antes de que puedas empezar a enviar mensajes, InstaVende tendrá que verificar tu empresa.
                    Cuando haya finalizado este proceso, recibirás un correo electrónico.
                </p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="/ChannelConfig" class="btn btn-outline-secondary">
                        <i class="bi bi-gear me-2"></i>Ver configuración
                    </a>
                    <a href="/Dashboard" class="btn btn-primary">
                        <i class="bi bi-house me-2"></i>Ir al dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ?? ERROR state (hidden by default) ?????????????????????????????????? -->
<div id="stateError" style="display:none">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="a-card text-center" style="padding:3rem 2rem">
                <div style="width:100px;height:100px;border-radius:50%;background:#fef2f2;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
                    <div style="width:72px;height:72px;border-radius:50%;background:#fee2e2;display:flex;align-items:center;justify-content:center">
                        <i class="bi bi-x-circle-fill" style="font-size:2rem;color:#ef4444"></i>
                    </div>
                </div>
                <h4 style="font-family:var(--font-heading);font-weight:700;color:#0f172a;margin-bottom:.5rem">
                    No se pudo conectar
                </h4>
                <p id="errorMsg" class="text-muted mb-4" style="font-size:.88rem">
                    Ocurrió un error durante la vinculación.
                </p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <button class="btn btn-outline-secondary" onclick="showState('main')">
                        <i class="bi bi-arrow-left me-2"></i>Volver
                    </button>
                    <button class="btn btn-primary" onclick="launchEmbeddedSignup()">
                        <i class="bi bi-arrow-repeat me-2"></i>Reintentar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ?? MAIN state ?????????????????????????????????????????????????????????? -->
<div id="stateMain">
<div class="row g-4">
    <!-- Hero card -->
    <div class="col-lg-8">
        <div class="a-card">
            <div class="a-card-body" style="padding:2.5rem 2rem">

