                            <i class="bi bi-whatsapp" style="font-size:2rem;color:#25D366"></i>
                        </div>
                        <div>
                            <h2 style="font-family:var(--font-heading);font-size:1.5rem;font-weight:800;color:#0f172a;margin-bottom:.3rem">
                                Conecta tu WhatsApp Business
