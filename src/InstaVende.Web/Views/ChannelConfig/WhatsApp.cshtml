@{
    ViewData["Title"] = "Conectar WhatsApp";
    bool isConnected  = ViewBag.IsConnected == true;
    string phoneNumber = ViewBag.PhoneNumber as string ?? "";
    DateTime? connectedAt = ViewBag.ConnectedAt as DateTime?;
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1" style="font-size:.78rem">
            <li class="breadcrumb-item"><a href="/ChannelConfig" class="text-muted">Canales</a></li>
            <li class="breadcrumb-item active">WhatsApp</li>
        </ol>
    </nav>
    <h1 class="topbar-page-title mb-0">Conectar WhatsApp</h1>
</div>

<div class="row justify-content-center">
<div class="col-lg-5">

@if (isConnected)
{
    <div class="a-card text-center" style="padding:2.5rem 2rem">
        <div style="width:96px;height:96px;border-radius:50%;background:#dcfce7;
                    display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
            <i class="bi bi-check-circle-fill" style="font-size:2.4rem;color:#16a34a"></i>
        </div>
        <h4 class="fw-bold mb-1" style="color:#0f172a">WhatsApp conectado</h4>
        <p class="text-muted mb-2" style="font-size:.88rem">El bot está activo y respondiendo mensajes.</p>
        @if (!string.IsNullOrEmpty(phoneNumber))
        {
            <p class="fw-semibold mb-1" style="color:#25D366;font-size:.95rem">
                <i class="bi bi-whatsapp me-1"></i>+@phoneNumber
            </p>
        }
        @if (connectedAt.HasValue)
        {
            <p class="text-muted mb-4" style="font-size:.8rem">
                Conectado el @connectedAt.Value.ToLocalTime().ToString("d MMM yyyy",
                    new System.Globalization.CultureInfo("es-PE"))
            </p>
        }
        else
        {
            <div class="mb-4"></div>
        }
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Inbox" class="btn btn-primary">
                <i class="bi bi-chat-dots me-2"></i>Ir a Mensajes
            </a>
            <form asp-action="Disconnect" method="post"
                  onsubmit="return confirm('Desconectar WhatsApp? El bot dejara de responder.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-plug me-2"></i>Desconectar
                </button>
            </form>
        </div>
    </div>
}
else
{
    <div class="a-card" style="padding:2rem">

        <div class="text-center mb-4">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                 style="width:72px;height:72px;background:#dcfce7">
                <i class="bi bi-whatsapp" style="font-size:2rem;color:#25D366"></i>
            </div>
            <h4 class="fw-bold mb-1" style="color:#0f172a">Escanea el codigo QR</h4>
            <p class="text-muted mb-0" style="font-size:.86rem">
                Abre WhatsApp &rarr; <strong>Dispositivos vinculados</strong> &rarr; <strong>Vincular dispositivo</strong>
            </p>
        </div>

        <div class="text-center mb-3">

            <div id="qrSpinner" class="py-4">
                <div class="spinner-border text-success mb-3" style="width:2.5rem;height:2.5rem"></div>
                <p id="qrSpinnerText" class="text-muted mb-0" style="font-size:.84rem">Iniciando servicio...</p>
            </div>

            <div id="qrImageWrap" style="display:none;flex-direction:column;align-items:center;gap:.75rem">
                <img id="qrImage" src="" alt="QR WhatsApp"
                     style="width:260px;height:260px;border-radius:12px;border:3px solid #bbf7d0;display:block" />
                <div style="width:260px;background:#f1f5f9;border-radius:99px;height:6px;overflow:hidden">
                    <div id="qrCountdownBar"
                         style="height:100%;width:100%;border-radius:99px;background:#25D366;
                                transition:width .9s linear,background .9s linear"></div>
                </div>
                <span id="qrCountdownText" class="text-muted" style="font-size:.78rem"></span>
            </div>

            <div id="qrAuthWrap" style="display:none" class="py-4">
                <div class="spinner-border text-success mb-3" style="width:2.5rem;height:2.5rem"></div>
                <p class="text-muted mb-0" style="font-size:.84rem">
                    <i class="bi bi-shield-check me-1"></i>Verificando sesion...
                </p>
            </div>

            <div id="qrError" style="display:none" class="py-3">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-3 mb-2 d-block"></i>
                <p class="text-muted mb-2" style="font-size:.85rem">No se pudo conectar al servicio WhatsApp local.</p>
                <p class="text-muted mb-3" style="font-size:.8rem">
                    Asegurate de que el servidor Node.js este corriendo:<br>
                    <code>cd wa-client &amp;&amp; npm start</code>
                </p>
                <button class="btn btn-sm btn-outline-secondary" onclick="WaQr.start()">
                    <i class="bi bi-arrow-repeat me-1"></i>Reintentar
                </button>
            </div>
        </div>

        <div class="d-flex align-items-center justify-content-center gap-2 py-2 px-3 rounded-3 mb-4"
             style="background:#f8fafc;border:1px solid #e2e8f0;font-size:.83rem;color:#475569">
            <span id="statusSpinner" class="spinner-border spinner-border-sm text-secondary"></span>
            <span id="statusText">Iniciando...</span>
        </div>

        <hr class="my-3" />
        <ol class="ps-3 mb-0" style="font-size:.84rem;line-height:2.2;color:#475569">
            <li>Abre <strong>WhatsApp</strong> en tu telefono</li>
            <li>Toca <strong>Mas opciones &rarr; Dispositivos vinculados</strong></li>
            <li>Toca <strong>Vincular un dispositivo</strong></li>
            <li>Escanea el codigo QR de arriba</li>
        </ol>
    </div>
}

</div>
</div>

@section Scripts {
@Html.AntiForgeryToken()
<script>
var WaQr = (function () {
  'use strict';

  var STATUS_URL  = '/ChannelConfig/WaStatus';
  var SAVE_URL    = '/ChannelConfig/SaveQrConnection';
  var POLL_FAST   = 1000;
  var POLL_NORMAL = 3000;
  var MAX_ERRORS  = 8;
  var QR_TTL_MS   = 18000;

  var _timer       = null;
  var _errors      = 0;
  var _lastQrUrl   = null;
  var _saving      = false;
  var _countdownId = null;

  var el = {
    spinner:       document.getElementById('qrSpinner'),
    spinnerText:   document.getElementById('qrSpinnerText'),
    imageWrap:     document.getElementById('qrImageWrap'),
    image:         document.getElementById('qrImage'),
    authWrap:      document.getElementById('qrAuthWrap'),
    error:         document.getElementById('qrError'),
    statusSpinner: document.getElementById('statusSpinner'),
    statusText:    document.getElementById('statusText'),
    countdownBar:  document.getElementById('qrCountdownBar'),
    countdownText: document.getElementById('qrCountdownText'),
  };

  // Guard: elements only exist on the QR (not-connected) view
  if (!el.spinner) return { start: function () {} };

  function start() {
    _errors    = 0;
    _saving    = false;
    _lastQrUrl = null;
    clearTimer();
    stopCountdown();
    showView('spinner');
    setStatus('Iniciando...', true);
    poll();
  }

  function poll() {
    if (document.hidden) { _timer = setTimeout(poll, 5000); return; }

    fetch(STATUS_URL, { cache: 'no-store' })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function (data) {
        _errors = 0;
        dispatch(data);
      })
      .catch(function () {
        _errors++;
        if (_errors >= MAX_ERRORS) {
          stopCountdown();
          showView('error');
          setStatus('Servicio no disponible', false);
          return;
        }
        setStatus('Reintentando (' + _errors + '/' + MAX_ERRORS + ')...', true);
        _timer = setTimeout(poll, POLL_NORMAL * 2);
      });
  }

  function dispatch(data) {
    var phase = data.state || (data.connected ? 'connected' : 'initializing');

    if (phase === 'connected') {
      if (_saving) return;
      _saving = true;
      stopCountdown();
      showView('spinner');
      el.spinnerText.textContent = 'Conectado. Guardando...';
      setStatus('Conectado', false);
      persist(data.info);
      return;
    }

    if (phase === 'authenticating') {
      stopCountdown();
      showView('auth');
      setStatus('QR escaneado, verificando...', true);
      _timer = setTimeout(poll, POLL_FAST);
      return;
    }

    if (phase === 'qr' && data.qrDataUrl) {
      if (data.qrDataUrl !== _lastQrUrl) {
        _lastQrUrl   = data.qrDataUrl;
        el.image.src = data.qrDataUrl;
        stopCountdown();
        if (data.qrExpiresAt) startCountdown(data.qrExpiresAt);
      }
      showView('image');
      setStatus('Escanea el QR con tu telefono', true);
      _timer = setTimeout(poll, POLL_NORMAL);
      return;
    }

    var msg = phase === 'disconnected'
      ? 'Servicio desconectado - reinicia wa-client'
      : 'Generando codigo QR...';
    el.spinnerText.textContent = msg;
    showView('spinner');
    setStatus(msg, phase !== 'disconnected');
    _timer = setTimeout(poll, POLL_FAST);
  }

  function persist(info) {
    clearTimer();
    var token = '';
    var inp = document.querySelector('[name="__RequestVerificationToken"]');
    if (inp) token = inp.value;
    fetch(SAVE_URL, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body:    JSON.stringify({ phone: info ? (info.phone || info.wid || null) : null }),
    })
    .then(function (r) {
      if (!r.ok) throw new Error('Save failed: ' + r.status);
      window.location.reload();
    })
    .catch(function (err) {
      _saving = false;
      showView('error');
      setStatus('Error al guardar la conexion', false);
      console.error('[WaQr] persist error:', err);
    });
  }

  function startCountdown(iso) {
    stopCountdown();
    var expiresAt = new Date(iso).getTime();
    (function tick() {
      var rem  = Math.max(0, expiresAt - Date.now());
      var pct  = (rem / QR_TTL_MS) * 100;
      var secs = Math.ceil(rem / 1000);
      el.countdownBar.style.width      = pct + '%';
      el.countdownBar.style.background = pct > 50 ? '#25D366' : pct > 25 ? '#f59e0b' : '#ef4444';
      el.countdownText.textContent     = secs > 0 ? 'Expira en ' + secs + ' s' : 'QR expirado';
      if (rem > 0) _countdownId = setTimeout(tick, 500);
    }());
  }

  function stopCountdown() {
    if (_countdownId) { clearTimeout(_countdownId); _countdownId = null; }
    if (el.countdownBar)  el.countdownBar.style.width = '100%';
    if (el.countdownText) el.countdownText.textContent = '';
  }

  function showView(name) {
    el.spinner.style.display   = name === 'spinner' ? ''     : 'none';
    el.imageWrap.style.display = name === 'image'   ? 'flex' : 'none';
    el.authWrap.style.display  = name === 'auth'    ? ''     : 'none';
    el.error.style.display     = name === 'error'   ? ''     : 'none';
  }

  function setStatus(text, spinning) {
    el.statusText.textContent      = text;
    el.statusSpinner.style.display = spinning ? '' : 'none';
  }

  function clearTimer() {
    if (_timer) { clearTimeout(_timer); _timer = null; }
  }

  document.addEventListener('visibilitychange', function () {
    if (!document.hidden && !_saving) { clearTimer(); poll(); }
  });

  start();
  return { start: start };

}());
</script>
}
