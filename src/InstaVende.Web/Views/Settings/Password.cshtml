@model InstaVende.Web.ViewModels.ChangePasswordViewModel
@{ ViewData["Title"] = "Cambiar contraseńa"; }

<div class="row g-4">
    <div class="col-lg-3">
        <div class="a-card">
            <div class="a-card-body p-0">
                <nav class="py-2">
                    <a asp-controller="Settings" asp-action="Account" class="sb-link"><i class="bi bi-person"></i> Mi perfil</a>
                    <a asp-controller="Settings" asp-action="Business" class="sb-link"><i class="bi bi-building"></i> Negocio</a>
                    <a asp-controller="Settings" asp-action="Password" class="sb-link active"><i class="bi bi-key"></i> Contraseńa</a>
                </nav>
            </div>
        </div>
    </div>
    <div class="col-lg-9">
        <div class="a-card" style="max-width:480px">
            <div class="a-card-header"><div class="a-card-title"><i class="bi bi-key-fill"></i> Cambiar contraseńa</div></div>
            <div class="a-card-body">
                <form asp-action="Password" method="post">
                    <div asp-validation-summary="ModelOnly" class="f-val-box"></div>
                    <div class="f-group">
                        <label class="f-label">Contraseńa actual</label>
                        <input asp-for="CurrentPassword" class="f-input" type="password" />
                        <span asp-validation-for="CurrentPassword" class="f-val-msg"></span>
                    </div>
                    <div class="f-group">
                        <label class="f-label">Nueva contraseńa</label>
                        <input asp-for="NewPassword" class="f-input" type="password" />
                        <span asp-validation-for="NewPassword" class="f-val-msg"></span>
                    </div>
                    <div class="f-group">
                        <label class="f-label">Confirmar nueva contraseńa</label>
                        <input asp-for="ConfirmNewPassword" class="f-input" type="password" />
                        <span asp-validation-for="ConfirmNewPassword" class="f-val-msg"></span>
                    </div>
                    <button type="submit" class="btn btn-primary mt-2">Actualizar contraseńa</button>
                </form>
            </div>
        </div>
    </div>
</div>
