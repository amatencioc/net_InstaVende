@model InstaVende.Web.ViewModels.UpgradeModalViewModel
<div class="a-card" style="max-width:520px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.18)">
    <div class="a-card-body text-center" style="padding:2.5rem 2rem">
        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
             style="width:72px;height:72px;background:#ede9fe">
            <i class="bi bi-@Model.Icon" style="font-size:2rem;color:#7c3aed"></i>
        </div>
        <h4 class="fw-bold mb-1" style="font-family:var(--font-heading);color:#0f172a">@Model.Title</h4>
        <p class="fw-semibold mb-2" style="color:#7c3aed;font-size:.95rem">@Model.Subtitle</p>
        <p class="text-muted mb-4" style="font-size:.85rem">@Model.Description</p>

        <div class="text-start mb-4">
            @foreach (var f in Model.Features)
            {
                <div class="d-flex align-items-start gap-2 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:32px;height:32px;background:#ede9fe">
                        <i class="bi bi-@f.Icon" style="font-size:.85rem;color:#7c3aed"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="font-size:.85rem">@f.Title</div>
                        <div class="text-muted" style="font-size:.78rem">@f.Desc</div>
                    </div>
                </div>
            }
        </div>

        <a href="@Model.CtaUrl" class="btn btn-primary w-100 mb-2">
            Ver planes y precios <i class="bi bi-arrow-right ms-1"></i>
        </a>
        <p class="text-muted mb-0" style="font-size:.76rem">
            <i class="bi bi-star-fill text-warning me-1"></i>
            Disponible desde el Plan @Model.PlanRequired
        </p>
    </div>
</div>
