<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")InstaVende</title>
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
<!-- Sidebar overlay (mobile) -->
<div class="sb-overlay" id="sbOverlay"></div>

<!-- Sidebar -->
<aside class="app-sidebar" id="appSidebar">
    <div class="sb-logo">
        <a asp-controller="Dashboard" asp-action="Index" class="sb-logo-text">Insta<span>Vende</span></a>
        <button class="sb-collapse-btn" id="sbCollapseBtn" title="Colapsar menú">
            <i class="bi bi-layout-sidebar-reverse" id="sbCollapseIcon"></i>
        </button>
    </div>
    <nav class="sb-nav">
        <div class="sb-section">Principal</div>
        <a asp-controller="Dashboard" asp-action="Index"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i><span class="sb-link-text">Dashboard</span>
        </a>
        <a asp-controller="Inbox" asp-action="Index"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inbox" ? "active" : "")">
            <i class="bi bi-chat-dots"></i><span class="sb-link-text">Mensajes</span>
            <span class="sb-badge" id="sbInboxCount" style="display:none">0</span>
        </a>
        <a asp-controller="Orders" asp-action="Index"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")">
            <i class="bi bi-bag-check"></i><span class="sb-link-text">Pedidos</span>
        </a>
        <a asp-controller="Products" asp-action="Index"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
            <i class="bi bi-box-seam"></i><span class="sb-link-text">Productos</span>
        </a>
        <div class="sb-section">Vendedor</div>
        <a asp-controller="Vendedor" asp-action="Personalidad"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vendedor" ? "active" : "")">
            <i class="bi bi-cpu"></i><span class="sb-link-text">Mi Vendedor</span>
        </a>
        <a asp-controller="ReminderTemplates" asp-action="Index"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ReminderTemplates" ? "active" : "")">
            <i class="bi bi-alarm"></i><span class="sb-link-text">Recordatorios</span>
        </a>
        <a asp-controller="Metricas" asp-action="Index"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Metricas" ? "active" : "")">
            <i class="bi bi-graph-up-arrow"></i><span class="sb-link-text">Métricas</span>
        </a>
        <div class="sb-section">Cuenta</div>
        <a asp-controller="ChannelConfig" asp-action="WhatsApp"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ChannelConfig" ? "active" : "")">
            <i class="bi bi-broadcast"></i><span class="sb-link-text">Canales</span>
            <span class="sb-badge" id="sbChannelBadge" style="display:none;background:#f59e0b">!</span>
        </a>
        <a asp-controller="AccountConfig" asp-action="Index"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AccountConfig" ? "active" : "")">
            <i class="bi bi-building-gear"></i><span class="sb-link-text">Configuración</span>
        </a>
        <a asp-controller="Settings" asp-action="Business"
           class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">
            <i class="bi bi-person-gear"></i><span class="sb-link-text">Mi perfil</span>
        </a>
    </nav>
    <div class="sb-bottom">
        <div class="sb-user">
            <div class="sb-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "U")</div>
            <div class="sb-user-info">
                <div class="sb-user-name">@User.Identity?.Name</div>
                <div class="sb-user-role">InstaVende Pro</div>
            </div>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="sb-logout">
                <i class="bi bi-box-arrow-right"></i>
                <span class="sb-link-text">Cerrar sesión</span>
            </button>
        </form>
    </div>
</aside>
<header class="app-topbar">
    <div class="topbar-left">
        <button class="sb-toggle" id="sbToggle"><i class="bi bi-list"></i></button>
        <span class="topbar-mobile-title">@ViewData["Title"]</span>
    </div>
    <div class="topbar-right">
        <span class="topbar-badge"><span class="dot"></span> Bot activo</span>
    </div>
</header>

<!-- Main content -->
<main class="app-content">
    @if (TempData["Success"] != null)
    {<div class="app-alert app-alert-success"><i class="bi bi-check-circle-fill"></i> @TempData["Success"]</div>}
    @if (TempData["Error"] != null)
    {<div class="app-alert app-alert-error"><i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]</div>}
    @RenderBody()
</main>

<!-- ── Global confirm/alert modal ───────────────────────────────────────── -->
<div class="iv-confirm-backdrop" id="ivConfirmBackdrop" role="dialog" aria-modal="true" aria-labelledby="ivConfirmTitle">
    <div class="iv-confirm-box">
        <div class="iv-confirm-icon danger" id="ivConfirmIcon"><i class="bi bi-exclamation-triangle-fill" id="ivConfirmIconI"></i></div>
        <div class="iv-confirm-title" id="ivConfirmTitle">¿Estás seguro?</div>
        <div class="iv-confirm-message" id="ivConfirmMessage"></div>
        <div class="iv-confirm-actions" id="ivConfirmActions">
            <button class="btn btn-outline-secondary" id="ivConfirmCancel">Cancelar</button>
            <button class="btn btn-danger" id="ivConfirmOk">Confirmar</button>
        </div>
    </div>
</div>
}
else
{
<main>@RenderBody()</main>
}

<script src="~/lib/jquery/jquery-3.7.1.min.js" asp-append-version="true"></script>
<script src="~/lib/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
<script src="~/lib/datatables/js/jquery.dataTables.min.js" asp-append-version="true"></script>
<script src="~/lib/datatables/js/dataTables.bootstrap5.min.js" asp-append-version="true"></script>
<script src="~/lib/chartjs/chart.umd.min.js" asp-append-version="true"></script>
<script src="~/lib/signalr/signalr.min.js" asp-append-version="true"></script>
<script>
  // Channel connection badge
  fetch('/ChannelConfig/IsConnected').then(r => r.json()).then(d => {
    if (!d.connected) { var b = document.getElementById('sbChannelBadge'); if(b) b.style.display=''; }
  }).catch(()=>{});

  var sidebar   = document.getElementById('appSidebar');
  var overlay   = document.getElementById('sbOverlay');
  var sbToggle  = document.getElementById('sbToggle');       // mobile hamburger (topbar)
  var collapseBtn = document.getElementById('sbCollapseBtn'); // desktop toggle (sidebar header)
  var collapseIcon = document.getElementById('sbCollapseIcon');

  // Desktop collapse/expand — persists in localStorage
  var COLLAPSED_KEY = 'sb_collapsed';
  function applySidebarState(collapsed) {
    if (collapsed) {
      sidebar.classList.add('collapsed');
      document.body.classList.add('sb-collapsed');
      if (collapseIcon) { collapseIcon.className = 'bi bi-layout-sidebar'; }
    } else {
      sidebar.classList.remove('collapsed');
      document.body.classList.remove('sb-collapsed');
      if (collapseIcon) { collapseIcon.className = 'bi bi-layout-sidebar-reverse'; }
    }
  }
  // Restore saved state — only when sidebar exists (authenticated pages)
  if (sidebar) {
    applySidebarState(localStorage.getItem(COLLAPSED_KEY) === '1');

    if (collapseBtn) {
      collapseBtn.addEventListener('click', function() {
        var isNowCollapsed = !sidebar.classList.contains('collapsed');
        applySidebarState(isNowCollapsed);
        localStorage.setItem(COLLAPSED_KEY, isNowCollapsed ? '1' : '0');
      });
    }

    // Mobile toggle
    if (sbToggle) {
      sbToggle.addEventListener('click', function() {
        sidebar.classList.toggle('open');
        overlay.classList.toggle('open');
      });
    }
    if (overlay) {
      overlay.addEventListener('click', function() {
        sidebar.classList.remove('open');
        overlay.classList.remove('open');
      });
    }
  }
</script>

<script>
// ── ivConfirm — reemplaza window.confirm con modal elegante ───────────────
// Uso: ivConfirm({ title, message, okLabel, type }).then(ok => { if(ok) ... })
// type: 'danger' | 'warning' | 'info'  (default: 'danger')
(function() {
  var backdrop = document.getElementById('ivConfirmBackdrop');
  var iconWrap = document.getElementById('ivConfirmIcon');
  var iconEl   = document.getElementById('ivConfirmIconI');
  var titleEl  = document.getElementById('ivConfirmTitle');
  var msgEl    = document.getElementById('ivConfirmMessage');
  var okBtn    = document.getElementById('ivConfirmOk');
  var cancelBtn= document.getElementById('ivConfirmCancel');
  var _resolve = null;

  // Modal elements only exist on authenticated pages — skip wiring on login/register
  if (!backdrop) {
    window.ivConfirm = function() { return Promise.resolve(true); };
    window.ivAlert   = function() { return Promise.resolve(true); };
    return;
  }

  var icons = {
    danger:  'bi-exclamation-triangle-fill',
    warning: 'bi-exclamation-circle-fill',
    info:    'bi-info-circle-fill'
  };
  var okColors = { danger: 'btn-danger', warning: 'btn-warning', info: 'btn-primary' };

  function open(opts) {
    var type  = opts.type || 'danger';
    titleEl.textContent = opts.title   || '¿Estás seguro?';
    msgEl.textContent   = opts.message || '';
    iconWrap.className  = 'iv-confirm-icon ' + type;
    iconEl.className    = 'bi ' + (icons[type] || icons.danger);
    okBtn.textContent   = opts.okLabel || 'Confirmar';
    okBtn.className     = 'btn ' + (okColors[type] || 'btn-danger');
    // show cancel only for confirm (not for alert)
    cancelBtn.style.display = opts.alertOnly ? 'none' : '';
    backdrop.classList.add('show');
    setTimeout(function() { okBtn.focus(); }, 50);
  }

  function close() { backdrop.classList.remove('show'); }

  okBtn.addEventListener('click', function() { close(); if (_resolve) { _resolve(true); _resolve = null; } });
  cancelBtn.addEventListener('click', function() { close(); if (_resolve) { _resolve(false); _resolve = null; } });
  backdrop.addEventListener('click', function(e) {
    if (e.target === backdrop) { close(); if (_resolve) { _resolve(false); _resolve = null; } }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && backdrop.classList.contains('show')) {
      close(); if (_resolve) { _resolve(false); _resolve = null; }
    }
  });

  // Public API
  window.ivConfirm = function(opts) {
    return new Promise(function(resolve) {
      _resolve = resolve;
      open(typeof opts === 'string' ? { message: opts } : opts);
    });
  };

  window.ivAlert = function(message, type) {
    return new Promise(function(resolve) {
      _resolve = resolve;
      open({ message: message, type: type || 'info', okLabel: 'Aceptar', alertOnly: true });
    });
  };
})();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
