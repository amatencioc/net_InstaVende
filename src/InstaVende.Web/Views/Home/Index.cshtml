    <div class="container">
        <div class="stats-grid">
            <div class="stat-item"><strong>+800</strong><span>ventas cerradas en automático</span></div>
            <div class="stat-div"></div>
            <div class="stat-item"><strong>98%</strong><span>satisfacción del cliente</span></div>
