    Layout = "_LandingLayout";
}

<!-- ANNOUNCE -->
<div class="announce-bar">
    <i class="bi bi-stars"></i>
    <span>InstaVende ya está disponible — configura tu bot en menos de 1 día</span>
    <a asp-controller="Account" asp-action="Register">Empezar gratis →</a>
</div>

<!-- NAV -->
<nav class="lp-nav">
    <div class="container">
        <a asp-controller="Home" asp-action="Index" class="lp-logo">Insta<span class="dot">Vende</span></a>
        <button class="nav-toggle" id="navToggle"><i class="bi bi-list"></i></button>
        <ul class="lp-links" id="navLinks">
            <li><a href="#como-funciona">Cómo funciona</a></li>
            <li><a href="#caracteristicas">Características</a></li>
            <li><a href="#canales">Canales</a></li>
            <li><a href="#precios">Precios</a></li>
            <li><a asp-controller="Account" asp-action="Login" class="btn-nav-login">Iniciar sesión</a></li>
            <li><a asp-controller="Account" asp-action="Register" class="btn-nav-cta"><i class="bi bi-rocket-takeoff-fill"></i> Crear Bot IA</a></li>
