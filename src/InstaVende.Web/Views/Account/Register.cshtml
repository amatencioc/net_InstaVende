@model InstaVende.Web.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Crear cuenta"; Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Crear cuenta — InstaVende</title>
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
<div class="auth-root">
    <!-- Panel izquierdo: branding -->
    <div class="auth-brand">
        <div class="auth-logo">Insta<span>Vende</span></div>
        <p class="auth-tagline">Empieza a vender en automático hoy</p>
        <div class="auth-features">
            <div class="auth-feat">
                <i class="bi bi-rocket-takeoff-fill"></i>
                <div><strong>Listo en menos de 1 día</strong><span>Configura tu bot y empieza a vender</span></div>
            </div>
            <div class="auth-feat">
                <i class="bi bi-gift"></i>
                <div><strong>14 días gratis</strong><span>Sin tarjeta de crédito requerida</span></div>
            </div>
            <div class="auth-feat">
                <i class="bi bi-headset"></i>
                <div><strong>Soporte dedicado</strong><span>Un asesor te acompaña en el setup</span></div>
            </div>
        </div>
    </div>
    <!-- Panel derecho: formulario -->
    <div class="auth-form-wrap">
        <div class="auth-box">
            <a asp-controller="Home" asp-action="Index" class="auth-back"><i class="bi bi-arrow-left"></i> Volver al inicio</a>
            <h1 class="auth-box-title">Crea tu cuenta</h1>
            <p class="auth-box-sub">Configura tu vendedor IA en minutos</p>
            <form asp-action="Register" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="f-val-box"></div>
                <div class="f-row">
                    <div class="f-group">
                        <label class="f-label">Nombre</label>
                        <input asp-for="FirstName" class="f-input" placeholder="Juan" autofocus />
                        <span asp-validation-for="FirstName" class="f-val-msg"></span>
                    </div>
                    <div class="f-group">
                        <label class="f-label">Apellido</label>
                        <input asp-for="LastName" class="f-input" placeholder="García" />
                        <span asp-validation-for="LastName" class="f-val-msg"></span>
                    </div>
                </div>
                <div class="f-group">
                    <label class="f-label">Nombre del Negocio</label>
                    <input asp-for="BusinessName" class="f-input" placeholder="Mi Tienda" />
                    <span asp-validation-for="BusinessName" class="f-val-msg"></span>
                </div>
                <div class="f-group">
                    <label class="f-label">Email</label>
                    <input asp-for="Email" class="f-input" placeholder="tu@negocio.com" />
                    <span asp-validation-for="Email" class="f-val-msg"></span>
                </div>
                <div class="f-group">
                    <label class="f-label">Contraseña</label>
                    <input asp-for="Password" class="f-input" placeholder="Mínimo 8 caracteres" />
                    <span asp-validation-for="Password" class="f-val-msg"></span>
                </div>
                <div class="f-group">
                    <label class="f-label">Confirmar contraseña</label>
                    <input asp-for="ConfirmPassword" class="f-input" placeholder="Repite tu contraseña" />
                    <span asp-validation-for="ConfirmPassword" class="f-val-msg"></span>
                </div>
                <button type="submit" class="btn-auth">Crear cuenta gratis</button>
            </form>
            <p class="auth-footer">¿Ya tienes cuenta? <a asp-action="Login">Iniciar sesión</a></p>
        </div>
    </div>
</div>
<script src="~/lib/jquery/jquery-3.7.1.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validate/jquery.validate.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
</body>
</html>
