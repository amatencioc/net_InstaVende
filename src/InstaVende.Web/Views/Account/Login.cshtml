@model InstaVende.Web.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Iniciar sesión"; Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Iniciar sesión — InstaVende</title>
    <link rel="stylesheet" href="~/css/fonts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
<div class="auth-root">
    <!-- Panel izquierdo: branding -->
    <div class="auth-brand">
        <div class="auth-logo">Insta<span>Vende</span></div>
        <p class="auth-tagline">Tu vendedor IA trabajando 24/7</p>
        <div class="auth-features">
            <div class="auth-feat">
                <i class="bi bi-whatsapp"></i>
                <div><strong>Multi-canal activo</strong><span>WhatsApp · Instagram · Facebook</span></div>
            </div>
            <div class="auth-feat">
                <i class="bi bi-graph-up-arrow"></i>
                <div><strong>Métricas en tiempo real</strong><span>Ventas, conversaciones y más</span></div>
            </div>
            <div class="auth-feat">
                <i class="bi bi-shield-check"></i>
                <div><strong>Panel seguro</strong><span>Acceso protegido con 2FA</span></div>
            </div>
        </div>
    </div>
    <!-- Panel derecho: formulario -->
    <div class="auth-form-wrap">
        <div class="auth-box">
            <a asp-controller="Home" asp-action="Index" class="auth-back"><i class="bi bi-arrow-left"></i> Volver al inicio</a>
            <h1 class="auth-box-title">Bienvenido de vuelta</h1>
            <p class="auth-box-sub">Inicia sesión para gestionar tu bot de ventas</p>
            <form asp-action="Login" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="f-val-box"></div>
                <div class="f-group">
                    <label class="f-label">Email</label>
                    <input asp-for="Email" class="f-input" placeholder="tu@negocio.com" autofocus />
                    <span asp-validation-for="Email" class="f-val-msg"></span>
                </div>
                <div class="f-group">
                    <label class="f-label">Contraseña</label>
                    <input asp-for="Password" class="f-input" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="f-val-msg"></span>
                </div>
                <div class="f-group" style="display:flex;align-items:center;justify-content:space-between">
                    <label class="f-check"><input asp-for="RememberMe" /> Recordarme</label>
                    <a href="#" class="f-link">¿Olvidaste tu contraseña?</a>
                </div>
                <button type="submit" class="btn-auth">Iniciar sesión</button>
            </form>
            <p class="auth-footer">¿No tienes cuenta? <a asp-action="Register">Crear cuenta gratis</a></p>
        </div>
    </div>
</div>
<script src="~/lib/jquery/jquery-3.7.1.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validate/jquery.validate.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
</body>
</html>
