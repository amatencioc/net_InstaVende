@model InstaVende.Web.ViewModels.ProductViewModel
@{ ViewData["Title"] = "Editar Producto"; }
<h2><i class="bi bi-pencil me-2"></i>Editar Producto</h2>
<div class="card" style="max-width:700px"><div class="card-body">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
        @if (!string.IsNullOrEmpty(Model.ImageUrl)) { <img src="@Model.ImageUrl" class="img-thumbnail mb-3" style="max-height:150px" /> }
        <div class="mb-3"><label asp-for="Name" class="form-label">Nombre *</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="Description" class="form-label">Descripción</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
        <div class="row g-2 mb-3">
            <div class="col"><label asp-for="Price" class="form-label">Precio *</label><input asp-for="Price" class="form-control" type="number" step="0.01" min="0" /><span asp-validation-for="Price" class="text-danger small"></span></div>
            <div class="col"><label asp-for="Stock" class="form-label">Stock</label><input asp-for="Stock" class="form-control" type="number" min="0" /></div>
            <div class="col"><label asp-for="CategoryId" class="form-label">Categoría</label><select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))"><option value="">Sin categoría</option></select></div>
        </div>
        <div class="mb-3"><label asp-for="ImageFile" class="form-label">Nueva Imagen (opcional)</label><input asp-for="ImageFile" class="form-control" type="file" accept="image/*" /></div>
        <div class="row g-2 mb-3">
            <div class="col-auto form-check ms-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Activo</label></div>
            <div class="col-auto form-check"><input asp-for="IsFeatured" class="form-check-input" /><label asp-for="IsFeatured" class="form-check-label">Destacado</label></div>
        </div>
        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
    </form>
</div></div>
@section Scripts { @await Html.PartialAsync("_ValidationScripts") }
