@model InstaVende.Web.ViewModels.ProductViewModel
@{ ViewData["Title"] = "Nuevo Producto"; }

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1" style="font-size:.78rem">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-muted">Productos</a></li>
            <li class="breadcrumb-item active">Nuevo producto</li>
        </ol>
    </nav>
    <h1 class="topbar-page-title mb-0"><i class="bi bi-plus-circle me-2"></i>Nuevo Producto</h1>
</div>

<div class="page-form-wrap">
    <div class="a-card">
        <div class="a-card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="app-alert app-alert-error py-2"></div>

                <div class="f-group">
                    <label class="f-label">Nombre *</label>
                    <input asp-for="Name" class="f-input" placeholder="Nombre del producto" />
                    <span asp-validation-for="Name" class="f-val-msg"></span>
                </div>

                <div class="f-group">
                    <label class="f-label">Descripción</label>
                    <textarea asp-for="Description" class="f-input" rows="3" placeholder="Describe el producto..."></textarea>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-4">
                        <label class="f-label">Precio *</label>
                        <input asp-for="Price" class="f-input" type="number" step="0.01" min="0" placeholder="0.00" />
                        <span asp-validation-for="Price" class="f-val-msg"></span>
                    </div>
                    <div class="col-sm-4">
                        <label class="f-label">Stock</label>
                        <input asp-for="Stock" class="f-input" type="number" min="0" placeholder="0" />
                    </div>
                    <div class="col-sm-4">
                        <label class="f-label">Categoría</label>
                        <select asp-for="CategoryId" class="f-input" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                            <option value="">Sin categoría</option>
                        </select>
                    </div>
                </div>

                <div class="f-group">
                    <label class="f-label">Imagen</label>
                    <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                </div>

                <div class="d-flex gap-3 mb-4">
                    <label class="f-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        Activo
                    </label>
                    <label class="f-check">
                        <input asp-for="IsFeatured" class="form-check-input" />
                        Destacado
                    </label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-floppy me-1"></i>Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScripts") }

