@model InstaVende.Web.ViewModels.ProductListViewModel
@{ ViewData["Title"] = "Productos"; }

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
        <h1 class="topbar-page-title mb-0"><i class="bi bi-box-seam me-2"></i>Productos</h1>
        <p class="text-muted small mb-0 mt-1">Administra tu catalogo de productos</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modalCategory">
            <i class="bi bi-tag me-1"></i>Categorías
        </button>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Producto
        </a>
    </div>
</div>

<div class="a-card mb-3">
    <div class="a-card-body d-flex flex-wrap gap-2">
        <input id="searchInput" type="text" class="f-input" placeholder="Buscar producto..."
               style="max-width:300px;min-width:180px" />
        <select id="categoryFilter" class="f-input" style="max-width:220px;min-width:140px">
            <option value="">Todas las categorías</option>
            @foreach (var cat in Model.Categories) { <option value="@cat.Id">@cat.Name</option> }
        </select>
    </div>
</div>

<div id="productGrid" class="row g-3"></div>

<div class="modal fade" id="modalCategory" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Categorías</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formCategory">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="catId" value="0" />
                    <div class="f-group">
                        <label class="f-label">Nombre</label>
                        <input id="catName" class="f-input" placeholder="Nombre de categoría" required />
                    </div>
                    <div class="f-group">
                        <label class="f-label">Descripción (opcional)</label>
                        <input id="catDesc" class="f-input" placeholder="Descripcion" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">Guardar</button>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { <script src="~/js/products.js" asp-append-version="true"></script> }
