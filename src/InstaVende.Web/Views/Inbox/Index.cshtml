@{ ViewData["Title"] = "Bandeja"; }
<div class="d-flex" style="height:calc(100vh - 80px)">
    <div class="border-end" style="width:320px;overflow-y:auto;flex-shrink:0">
        <div class="p-2 border-bottom bg-light">
            <input id="inboxSearch" class="form-control form-control-sm mb-2" placeholder="Buscar..." />
            <div class="d-flex gap-1 flex-wrap align-items-center">
                <button class="btn btn-sm btn-outline-secondary active" data-channel="">Todos</button>
                <button class="btn btn-sm btn-outline-success" data-channel="1"><i class="bi bi-whatsapp"></i></button>
                <button class="btn btn-sm btn-outline-primary" data-channel="2"><i class="bi bi-facebook"></i></button>
                <button class="btn btn-sm btn-outline-danger" data-channel="3"><i class="bi bi-instagram"></i></button>
                <select id="statusFilter" class="form-select form-select-sm" style="width:auto">
                    <option value="">Todos estados</option>
                    <option value="1">Bot activo</option>
                    <option value="2">Esperando humano</option>
                    <option value="3">Humano activo</option>
                    <option value="4">Resuelto</option>
                </select>
            </div>
        </div>
        <div id="conversationList"></div>
    </div>
    <div class="flex-fill d-flex flex-column">
        <div id="chatHeader" class="p-3 border-bottom bg-light d-none">
            <div class="d-flex justify-content-between align-items-center">
                <div><strong id="chatContactName"></strong><span id="chatChannelBadge" class="badge ms-2"></span><span id="chatStatusBadge" class="badge ms-1"></span></div>
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-warning" onclick="setConvStatus(2)" title="Transferir a humano"><i class="bi bi-person-raised-hand"></i></button>
                    <button class="btn btn-sm btn-outline-success" onclick="setConvStatus(3)" title="Tomar conversación"><i class="bi bi-person-check"></i></button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="setConvStatus(4)" title="Resolver"><i class="bi bi-check2-circle"></i></button>
                </div>
            </div>
        </div>
        <div id="messageThread" class="flex-fill p-3" style="overflow-y:auto;background:#f0f2f5"></div>
        <div id="chatInput" class="p-3 border-top bg-light d-none">
            <div class="input-group"><textarea id="msgInput" class="form-control" rows="2" placeholder="Escribe un mensaje... (Ctrl+Enter para enviar)" style="resize:none"></textarea><button id="sendBtn" class="btn btn-primary"><i class="bi bi-send"></i></button></div>
        </div>
    </div>
</div>
@section Scripts {
<script>var businessId = @ViewBag.BusinessId;</script>
<script src="~/js/inbox.js" asp-append-version="true"></script>
}
