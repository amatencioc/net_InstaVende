@model InstaVende.Web.ViewModels.BotConfigViewModel
@{ ViewData["Title"] = "Mi Vendedor – ChatBot"; }

@await Html.PartialAsync("_VendedorTabs", "bot")

<ul class="nav nav-tabs mb-4" id="botTabs">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabConfig">Configuración</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabIntents">Intenciones</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabKnowledge">Base de Conocimiento</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabPreview">Probar Bot</a></li>
</ul>

<div class="tab-content">

<!-- TAB: Configuración -->
<div class="tab-pane fade show active" id="tabConfig">
    <div class="a-card page-form-wrap">
        <div class="a-card-body">
            <form id="formConfig">
                @Html.AntiForgeryToken()
                <div class="f-row mb-3">
                    <div class="f-group">
                        <label class="f-label">Nombre del Bot</label>
                        <input name="BotName" class="f-input" value="@Model.BotName" required />
                    </div>
                    <div class="f-group">
                        <label class="f-label">Idioma</label>
                        <select name="Language" class="f-input">
                            <option value="es" selected="@(Model.Language=="es")">Español</option>
                            <option value="en" selected="@(Model.Language=="en")">English</option>
                            <option value="pt" selected="@(Model.Language=="pt")">Português</option>
                        </select>
                    </div>
                </div>
                <div class="f-group mb-3">
                    <label class="f-label">Personalidad</label>
                    <input name="Personality" class="f-input" value="@Model.Personality" placeholder="Ej: Amigable, orientado a ventas" />
                </div>
                <div class="f-group mb-3">
                    <label class="f-label">Prompt base</label>
                    <textarea name="BaseSystemPrompt" class="f-input" rows="4">@Model.BaseSystemPrompt</textarea>
                </div>
                <div class="f-row mb-3">
                    <div class="f-group">
                        <label class="f-label">Nivel de Interacción</label>
                        <select name="InteractionLevel" class="f-input">
                            <option value="1" selected="@(Model.InteractionLevel==InstaVende.Core.Enums.InteractionLevel.Minimal)">Mínimo</option>
                            <option value="2" selected="@(Model.InteractionLevel==InstaVende.Core.Enums.InteractionLevel.Standard)">Estándar</option>
                            <option value="3" selected="@(Model.InteractionLevel==InstaVende.Core.Enums.InteractionLevel.Proactive)">Proactivo</option>
                        </select>
                    </div>
                    <div class="f-group">
                        <label class="f-label">Mensaje fallback</label>
                        <input name="FallbackMessage" class="f-input" value="@Model.FallbackMessage" required />
                    </div>
                </div>
                <div class="mb-3 form-check form-switch">
                    <input name="EnableHandoff" class="form-check-input" type="checkbox" id="chkHandoff" @(Model.EnableHandoff?"checked":"") value="true" />
                    <label class="form-check-label" for="chkHandoff">Permitir transferencia a humano</label>
                </div>
                <div class="f-group mb-3">
                    <label class="f-label">Frase de transferencia</label>
                    <input name="HandoffTriggerPhrase" class="f-input" value="@Model.HandoffTriggerPhrase" placeholder="Ej: hablar con agente" />
                </div>
                <div class="mb-3 form-check form-switch">
                    <input name="IsActive" class="form-check-input" type="checkbox" id="chkActive" @(Model.IsActive?"checked":"") value="true" />
                    <label class="form-check-label" for="chkActive">Bot activo</label>
                </div>
                <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i> Guardar configuración</button>
            </form>
        </div>
    </div>
</div>

<!-- TAB: Intenciones -->
<div class="tab-pane fade" id="tabIntents">
    <div class="a-card">
        <div class="a-card-header">
            <div class="a-card-title"><i class="bi bi-lightning-charge-fill"></i> Intenciones</div>
            <button class="btn btn-primary btn-sm" onclick="openIntentModal(0)">
                <i class="bi bi-plus-circle me-1"></i>Nueva
            </button>
        </div>
        <div class="a-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead><tr><th>Intención</th><th>Frases</th><th>Respuesta</th><th>Prior.</th><th>Estado</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var i in (IEnumerable<dynamic>)ViewBag.Intents)
                        {
                            <tr>
                                <td>@i.IntentName</td>
                                <td><small class="text-muted">@i.TriggerPhrases</small></td>
                                <td>@i.Response</td>
                                <td>@i.Priority</td>
                                <td>@(i.IsActive ? Html.Raw("<span class='badge bg-success'>Activo</span>") : Html.Raw("<span class='badge bg-secondary'>Inactivo</span>"))</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary me-1" onclick="openIntentModal(@i.Id)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteIntent(@i.Id)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- TAB: Base de Conocimiento -->
<div class="tab-pane fade" id="tabKnowledge">
    <div class="a-card">
        <div class="a-card-header">
            <div class="a-card-title"><i class="bi bi-book-fill"></i> Base de Conocimiento</div>
            <button class="btn btn-primary btn-sm" onclick="openKbModal(0)">
                <i class="bi bi-plus-circle me-1"></i>Nueva
            </button>
        </div>
        <div class="a-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead><tr><th>Pregunta</th><th>Respuesta</th><th>Categoría</th><th>Estado</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var k in (IEnumerable<dynamic>)ViewBag.Knowledge)
                        {
                            <tr>
                                <td>@k.Question</td>
                                <td>@k.Answer</td>
                                <td>@k.Category</td>
                                <td>@(k.IsActive ? Html.Raw("<span class='badge bg-success'>Activo</span>") : Html.Raw("<span class='badge bg-secondary'>Inactivo</span>"))</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary me-1" onclick="openKbModal(@k.Id)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteKb(@k.Id)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- TAB: Probar Bot -->
<div class="tab-pane fade" id="tabPreview">
    <div class="a-card" style="max-width:540px">
        <div class="a-card-header" style="background:var(--brand);border-radius:10px 10px 0 0">
            <div class="a-card-title text-white"><i class="bi bi-chat-dots me-2"></i>Prueba tu Bot</div>
        </div>
        <div class="a-card-body p-0">
            <div id="previewMessages" style="height:340px;overflow-y:auto;padding:1rem;background:#f8fafc"></div>
        </div>
        <div style="border-top:1px solid #e2e8f0;padding:.75rem">
            <div class="d-flex gap-2">
                <input id="previewInput" type="text" class="f-input flex-grow-1" placeholder="Escribe un mensaje..." />
                <button id="previewSend" class="btn btn-primary"><i class="bi bi-send"></i></button>
            </div>
        </div>
    </div>
</div>

</div><!-- /tab-content -->

<!-- Modal: Intención -->
<div class="modal fade" id="modalIntent" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Intención</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formIntent">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="intentId" value="0" />
                    <div class="f-group mb-2">
                        <label class="f-label">Nombre</label>
                        <input id="intentName" class="f-input" required />
                    </div>
                    <div class="f-group mb-2">
                        <label class="f-label">Frases disparadoras (JSON)</label>
                        <textarea id="intentPhrases" class="f-input" rows="3" placeholder='["hola","buenos días"]' required></textarea>
                    </div>
                    <div class="f-group mb-2">
                        <label class="f-label">Respuesta</label>
                        <textarea id="intentResponse" class="f-input" rows="3" required></textarea>
                    </div>
                    <div class="f-row mb-2">
                        <div class="f-group">
                            <label class="f-label">Prioridad</label>
                            <input id="intentPriority" class="f-input" type="number" value="0" />
                        </div>
                        <div class="f-group d-flex align-items-end pb-1">
                            <div class="form-check form-switch">
                                <input id="intentActive" class="form-check-input" type="checkbox" checked />
                                <label class="form-check-label" for="intentActive">Activo</label>
                            </div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Conocimiento -->
<div class="modal fade" id="modalKb" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Entrada de Conocimiento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formKb">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="kbId" value="0" />
                    <div class="f-group mb-2">
                        <label class="f-label">Pregunta</label>
                        <input id="kbQuestion" class="f-input" required />
                    </div>
                    <div class="f-group mb-2">
                        <label class="f-label">Respuesta</label>
                        <textarea id="kbAnswer" class="f-input" rows="3" required></textarea>
                    </div>
                    <div class="f-group mb-2">
                        <label class="f-label">Categoría</label>
                        <input id="kbCategory" class="f-input" />
                    </div>
                    <div class="mb-2 form-check form-switch">
                        <input id="kbActive" class="form-check-input" type="checkbox" checked />
                        <label class="form-check-label" for="kbActive">Activo</label>
                    </div>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <script src="~/js/bot-trainer.js" asp-append-version="true"></script> }
